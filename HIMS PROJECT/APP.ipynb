    "def assign_ddepartment(symptoms):\n",
    "    s = symptoms.lower()\n",
    "    if 'chest' in s or 'heart' in s:\n",
    "        return 'Caridology'\n",
    "    elif 'bone' in s or 'fracture' in s:\n",
    "        return'Orthopedics'\n",
    "    elif 'skin' in s:\n",
    "        return 'Dermatology'\n",
    "    elif 'eye' in s:\n",
    "        return'Ophthalmaology'\n",
    "    elif 'brain' in s or 'headache' in s:\n",
    "        return 'Neurology'\n",
    "    elif 'lung' in s:\n",
    "        return 'Pulmonology'\n",
    "    elif 'teeth' in s: \n",
    "        return'Dentistry'\n",
    "    return 'Genral Medicine'"
   ]
  },
